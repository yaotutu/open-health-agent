# Server port
PORT=3001

# Workspace path
WORKSPACE_PATH=./workspace

# LLM Provider (anthropic, openai, kimi-coding, etc.)
LLM_PROVIDER=kimi-coding

# LLM Model
LLM_MODEL=kimi-k2.5

# API Keys (pi-ai auto-reads from env vars)
# Set your API key based on provider:
KIMI_API_KEY=your-kimi-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-key-here
# OPENAI_API_KEY=your-openai-key-here

# Debug mode (set to 1 to enable)
DEBUG=
