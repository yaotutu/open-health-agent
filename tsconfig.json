{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "resolveJsonModule": true,
    "declaration": true,
    "types": ["node", "bun-types"],
    "paths": {
      "@features/*": ["./src/features/*"],
      "@store/*": ["./src/store/*"],
      "@agent/*": ["./src/agent/*"],
      "@prompts/*": ["./src/prompts/*"],
      "@channels/*": ["./src/channels/*"],
      "@session/*": ["./src/session/*"],
      "@config": ["./src/config.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}