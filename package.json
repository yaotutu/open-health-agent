{
  "name": "healthclaw",
  "version": "1.0.0",
  "description": "Personal health advisor agent",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"bun run server\" \"cd web && npx vite --host\"",
    "server": "bun run src/main.ts",
    "build": "tsc && cd web && npx vite build",
    "typecheck": "tsc --noEmit",
    "db:push": "drizzle-kit push"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/node-cron": "^3.0.11",
    "@types/ws": "^8.18.1",
    "better-sqlite3": "^12.8.0",
    "bun-types": "^1.3.11",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.62.0",
    "@mariozechner/pi-ai": "^0.62.0",
    "@sinclair/typebox": "^0.34.48",
    "cron-parser": "^5.5.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.40.0",
    "hono": "^4.12.9",
    "node-cron": "^4.2.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pure-qqbot": "^1.0.0",
    "weixin-ilink": "^0.1.0",
    "ws": "^8.20.0"
  }
}
